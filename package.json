{
    "name": "mutter-games-admin-api",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "dev": "vercel dev",
        "start": "node",
        "check:vercel-functions": "node scripts/check-vercel-functions-limit.js",
        "build": "find api -name '*.ts' -print0 | xargs -0 tsc --noEmit --skipLibCheck --moduleResolution node --target ES2022 --module commonjs --esModuleInterop",
        "audit:prod": "npm audit --omit=dev --audit-level=moderate",
        "audit:all": "npm audit --audit-level=high"
    },
    "dependencies": {
        "firebase-admin": "13.9.0"
    },
    "devDependencies": {
        "@vercel/node": "5.8.0",
        "tsx": "4.21.0",
        "typescript": "5.9.3"
    },
    "packageManager": "npm@9.9.4",
    "overrides": {
        "protobufjs": "7.5.8",
        "@protobufjs/utf8": "1.1.1",
        "jsonwebtoken": {
            "jws": "3.2.3"
        },
        "google-auth-library": {
            "jws": "4.0.1"
        },
        "gtoken": {
            "jws": "4.0.1"
        },
        "firebase-admin": {
            "uuid": "11.1.1"
        },
        "path-to-regexp": "6.3.0",
        "undici": "6.25.0",
        "minimatch": "10.2.5",
        "smol-toml": "1.6.1",
        "ajv": "8.20.0"
    }
}
